# Cumbreva — variables de entorno
# Copia este archivo como .env.local y completa los valores.

# Resend (envío de correos de la lista de espera)
# API key desde https://resend.com/api-keys
RESEND_API_KEY=

# Remitente verificado en Resend. Para pruebas puedes usar:
#   Cumbreva <onboarding@resend.dev>
# En producción, un dominio verificado, ej: Cumbreva <hola@cumbreva.com>
FROM_EMAIL=

# Correo donde recibes los leads de la lista de espera
ADMIN_EMAIL=medialabproyectos@gmail.com

# Dominio de producción (canonical, sitemap, OG, JSON-LD y logo de los correos)
NEXT_PUBLIC_SITE_URL=https://cumbreva.medialab.design

# --- Calculadora de autonomía ---------------------------------------------

# Vercel KV (Upstash Redis) — base de datos de cuota, usuarios, OTP, sesiones e
# historial. Misma tecnología que Medialab Ingeniería (UXBox). Estas variables las
# inyecta Vercel automáticamente al crear el store (Storage → KV → Connect).
# En local, cópialas desde el dashboard de Vercel para probar con BD real.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# OpenRouteService — ruteo y elevación (server-side, NUNCA en el cliente).
# Key gratuita en https://openrouteservice.org/dev/#/signup (sin tarjeta).
ORS_API_KEY=

# Token secreto del panel de administración (/admin). Inventa una cadena larga.
# Sin esta variable, el panel queda deshabilitado.
ADMIN_TOKEN=
